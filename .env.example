# =============================================================================
# MilTrack — Environment Variables
# =============================================================================
#
# LOCAL DEV:  Copy to .env and fill in values. python-dotenv loads automatically.
# DATABRICKS APPS: Set via app.yaml (non-sensitive) and Secret Scopes (secrets).
#                  The Databricks SDK handles auth automatically — no PAT needed.
# =============================================================================

# --- AI Intelligence Pipeline ---

# Brave Search API — $5/1k requests
# Sign up at https://brave.com/search/api/
# In Databricks Apps: stored in Secret Scope, injected via app.yaml valueFrom
BRAVE_SEARCH_API_KEY=your-brave-api-key

# --- Databricks LLM ---

# Workspace URL
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# PAT (local dev only). In Databricks Apps: uses app's service principal, no PAT needed.
DATABRICKS_TOKEN=dapi-your-token

# AI Gateway endpoint (recommended — supports Claude, GPT, etc.)
DATABRICKS_ENDPOINT_URL=https://your-id.ai-gateway.cloud.databricks.com/mlflow/v1/chat/completions

# LLM model fallback chain (comma-separated: if first hits rate limit, tries next)
DATABRICKS_LLM_MODEL=databricks-claude-opus-4-6,databricks-claude-sonnet-4-8,databricks-meta-llama-3-1-70b-instruct

# --- Death toll (UCDP verified) ---

# UCDP API token — request at mertcan.yilmaz@pcr.uu.se (free, describe project)
# Without this, death toll uses only GDELT (AI-inferred, unverified)
# Header: x-ucdp-access-token. Limit: 5,000 requests/day.
UCDP_ACCESS_TOKEN=your-ucdp-token

# --- FlightAware AeroAPI (full flight routes) ---

# Free tier: 500 requests/month, no credit card
# Sign up: https://www.flightaware.com/account/join/
# API key: https://www.flightaware.com/commercial/aeroapi/key
FLIGHTAWARE_API_KEY=your-flightaware-key

# --- X (Twitter) — optional ---

# Option A: Brave Search (free with existing key) — web search site:x.com
# Uses BRAVE_SEARCH_API_KEY above. No extra cost.

# Option B: X API v2 Bearer Token — pay-per-use at developer.x.com
# X_API_BEARER_TOKEN=your-x-bearer-token

# --- Optional data sources ---

# OpenSky Network — optional, increases ADS-B rate limits
# OPENSKY_CLIENT_ID=your-client-id
# OPENSKY_CLIENT_SECRET=your-client-secret

# aisstream.io — free API key at https://aisstream.io
# AISSTREAM_API_KEY=your-aisstream-api-key
